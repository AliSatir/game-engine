# Üçgenleştirilmiş Küp OBJ Dosyası
# 8 Köşe Noktası (Vertices)
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v -1.0  1.0  1.0
v  1.0  1.0  1.0
v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v -1.0  1.0 -1.0
v  1.0  1.0 -1.0

# Doku Koordinatları (Texture Coordinates - UV)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Yüzey Normalleri (Normals - Işıklandırma için gerekli)
vn 0.0 0.0 1.0
vn 0.0 0.0 -1.0
vn 0.0 1.0 0.0
vn 0.0 -1.0 0.0
vn 1.0 0.0 0.0
vn -1.0 0.0 0.0

# Yüzeyler (Faces) - Her kare yüzey 2 üçgene bölünmüştür
# Format: f v/vt/vn
# Ön Yüz
f 1/1/1 2/2/1 4/3/1
f 1/1/1 4/3/1 3/4/1
# Arka Yüz
f 6/1/2 5/2/2 7/3/2
f 6/1/2 7/3/2 8/4/2
# Üst Yüz
f 3/1/3 4/2/3 8/3/3
f 3/1/3 8/3/3 7/4/3
# Alt Yüz
f 5/1/4 6/2/4 2/3/4
f 5/1/4 2/3/4 1/4/4
# Sağ Yüz
f 2/1/5 6/2/5 8/3/5
f 2/1/5 8/3/5 4/4/5
# Sol Yüz
f 5/1/6 1/2/6 3/3/6
f 5/1/6 3/3/6 7/4/6